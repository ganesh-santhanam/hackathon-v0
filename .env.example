# Local demo defaults. Copy to .env for local use; do not commit .env.

INDUSTRIAL_AI_ENV=demo
INDUSTRIAL_AI_PRODUCTION=false
INDUSTRIAL_AI_LOG_LEVEL=INFO

# Local Ollama settings. OLLAMA_GENERATE_URL overrides OLLAMA_BASE_URL when set.
OLLAMA_MODEL=gemma3:4b
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_GENERATE_URL=http://localhost:11434/api/generate

# Docker Compose uses the service URL for Qdrant. The Python demo currently uses local
# embedded Qdrant paths unless a script explicitly accepts a URL.
QDRANT_URL=http://localhost:6333

# Optional OpenAI-compatible judge endpoint for local/vLLM evaluation.
OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_API_KEY=
