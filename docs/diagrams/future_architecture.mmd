flowchart LR
    Plant[Plant telemetry, images, work orders] --> Kafka[Kafka or managed stream]
    Kafka --> Stream[Flink or Spark Streaming<br/>windowed features and enrichment]
    Stream --> FS[Feature store<br/>online/offline consistency]
    Stream --> Lake[Lakehouse or Snowflake<br/>historical analytics]
    Images[Inspection images] --> Obj[Object storage]
    FS --> API[Investigation API]
    Obj --> API
    API --> Graph[LangGraph investigation service]
    Graph --> Telemetry[Telemetry model serving]
    Graph --> Vision[Vision model serving]
    Graph --> Vector[(Shared vector DB<br/>similar incidents)]
    Graph --> Gateway[Model gateway<br/>base, LoRA, fallback routing]
    Graph --> Policy[Policy service<br/>severity and guardrails]
    Policy --> Approval[Approval system<br/>human review]
    Approval --> Audit[Audit logs<br/>approvals, overrides, actions]
    Graph --> Obs[Observability<br/>LangSmith, OpenTelemetry, metrics]
    Gateway --> Registry[Model and prompt registry]
    Lake --> BI[Operations BI<br/>MTTR, downtime, quality trends]
